# Example Environment Configuration
# Copy this to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=orcaflow

# ML Model
MODEL_PATH=orcaflow/models/job_classifier.pkl
MODEL_CACHE_ENABLED=true

# Control Plane (gRPC)
CONTROL_PLANE_HOST=localhost
CONTROL_PLANE_PORT=7070

# Cluster Configuration
MAX_WORKERS=8
MAX_SPARK_JOBS=10
DEFAULT_MEMORY_MB=2048
DEFAULT_CPU_CORES=2

# Monitoring
PROMETHEUS_URL=http://localhost:9090
METRICS_PORT=8001
METRICS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/orcaflow.log

# Development
DEBUG=true
ENVIRONMENT=development  # production, staging, development
